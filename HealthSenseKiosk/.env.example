# ESP32 Device Configuration
# Update this IP address to match your ESP32 device
VITE_ESP32_BASE_URL=http://192.168.1.100

# Cloud Backend Configuration
VITE_CLOUD_BASE_URL=https://healthsense-api.vercel.app

# API Key (if required by backend)
VITE_API_KEY=

# Mock Mode (set to false to use real devices)
VITE_MOCK_MODE=false
