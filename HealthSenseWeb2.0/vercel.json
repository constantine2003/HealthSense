{
  "headers": [
    {
      "source": "/(.*).apk",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=HealthSense.apk"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!.*\\.apk$).*)",
      "destination": "/index.html"
    }
  ]
}